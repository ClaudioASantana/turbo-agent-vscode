{
  "name": "turbo-agent-vscode",
  "displayName": "Turbo Agent",
  "description": "Seu assistente pessoal conectado ao Turbo-Agent local",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "turbo-agent-sidebar",
          "title": "Turbo Agent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "turbo-agent-sidebar": [
        {
          "type": "webview",
          "id": "turboAgent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "turboAgent.start",
        "title": "Start Turbo Agent"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.4.3"
  }
}
